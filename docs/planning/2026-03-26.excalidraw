    {
      "id": "-qsXBkBMEb_lrGYrMJHc0",
      "type": "text",
      "x": 764.4367009003336,
      "y": -641.4481861780205,
      "width": 432.3674871077802,
      "height": 562.5,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2W",
      "roundness": null,
      "seed": 1417341365,
      "version": 574,
      "versionNonce": 512757691,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774574591283,
      "link": null,
      "locked": false,
      "text": "Idea 1: Store in \"corpus/\" directory that\nis structured similarly to the database.\nUsers get folders, and projects get folders\nunder each user.  Each user and project has\na unique key, generated from the database.\ncorpus/\n  ├── u-1/\n  │   ├── b-1/\n  │   │   ├── thing1\n  │   │   ├── thing2\n  │   │   └── thing3\n  │   └── b-2/\n  │       ├── thing1\n  │       ├── thing2\n  │       └── thing3\n  └── u-2/\n      ├── b-3/\n      │   ├── thing1\n      │   ├── thing2\n      │   └── thing3\n      └── b-4/\n          ├── thing1\n          ├── thing2\n          └── thing3\n",
      "fontSize": 18,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Idea 1: Store in \"corpus/\" directory that is structured similarly to the database.  Users get folders, and projects get folders under each user.  Each user and project has a unique key, generated from the database.\ncorpus/\n  ├── u-1/\n  │   ├── b-1/\n  │   │   ├── thing1\n  │   │   ├── thing2\n  │   │   └── thing3\n  │   └── b-2/\n  │       ├── thing1\n  │       ├── thing2\n  │       └── thing3\n  └── u-2/\n      ├── b-3/\n      │   ├── thing1\n      │   ├── thing2\n      │   └── thing3\n      └── b-4/\n          ├── thing1\n          ├── thing2\n          └── thing3\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
