      "boundElements": [],
      "updated": 1774574579306,
      "link": null,
      "locked": false,
      "text": "Where should files be stored?  In the file\nsystem?  In a database?  Some files may be\nlarge: e.g. a 65 mb / 600-page pdf",
      "fontSize": 13,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Where should files be stored?  In the file system?  In a database?  Some files may be large: e.g. a 65 mb / 600-page pdf",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
